{
  "id": "truoc",
  "title": "...trước",
  "terms": [
    "trước"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "Used after time nouns to refer to the previous one (last... / ... ago)."
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Tuần trước",
          "en": "last week"
        },
        {
          "type": "example",
          "vi": "Tháng trước",
          "en": "last month"
        },
        {
          "type": "example",
          "vi": "Năm trước",
          "en": "last year"
        },
        {
          "type": "example",
          "vi": "Tuần trước mình đi du lịch.",
          "en": "Last week I went traveling."
        },
        {
          "type": "example",
          "vi": "Năm trước anh ấy sống ở Mỹ.",
          "en": "Last year he lived in the US."
        }
      ]
    }
  ]
}
