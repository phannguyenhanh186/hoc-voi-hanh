{
  "id": "duration",
  "title": "Duration",
  "terms": [],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "Duration (length of time). Used to express how long an action lasts or has lasted. The duration phrase comes directly after the verb — no preposition needed, unlike English \"for\"."
        }
      ]
    },
    {
      "label": "Structure",
      "blocks": [
        {
          "type": "text",
          "text": "[Subject] + [verb] + [duration]  —  [Subject] [verb] (for) [duration]"
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Mình ngủ 30 phút.",
          "en": "I sleep (for) 30 minutes."
        },
        {
          "type": "example",
          "vi": "Mình học tiếng Việt 1 giờ.",
          "en": "I study Vietnamese (for) 1 hour."
        },
        {
          "type": "example",
          "vi": "Chị ấy du lịch Việt Nam 4 ngày.",
          "en": "She travels in Vietnam (for) 4 days."
        },
        {
          "type": "example",
          "vi": "Anh Nam sống ở Mỹ 10 năm.",
          "en": "Anh Nam has lived in the US (for) 10 years."
        },
        {
          "type": "example",
          "vi": "Mình làm việc 8 giờ mỗi ngày.",
          "en": "I work 8 hours every day."
        }
      ]
    },
    {
      "label": "Note",
      "blocks": [
        {
          "type": "text",
          "text": "Common units (smallest to largest): phút (minute) → giờ (hour) → ngày (day) → tuần (week) → tháng (month) → năm (year)."
        }
      ]
    }
  ]
}
