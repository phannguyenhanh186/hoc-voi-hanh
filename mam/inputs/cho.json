{
  "id": "cho",
  "title": "Cho...",
  "terms": [
    "Cho",
    "ít",
    "nhiều"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "Cho mình/em/anh/chị [x] [drink/food] — used to order or request something, literally \"give [pronoun] [item].\""
        }
      ]
    },
    {
      "label": "Structure",
      "blocks": [
        {
          "type": "text",
          "text": "Cho + [pronoun] + [quantity] + [item]"
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Cho em một cà phê đen.",
          "en": "I'll have one black coffee."
        },
        {
          "type": "example",
          "vi": "Cho mình một phở bò.",
          "en": "I'll have one beef pho."
        },
        {
          "type": "example",
          "vi": "Cho chị một trà xanh.",
          "en": "I'll have one green tea."
        }
      ]
    },
    {
      "label": "Note",
      "blocks": [
        {
          "type": "text",
          "text": "ít / nhiều + đường / đá / sữa:  \"ít\" = less/little, \"nhiều\" = more/much."
        },
        {
          "type": "text",
          "text": "ít đường = less sugar · nhiều đá = more ice · ít sữa = less milk."
        },
        {
          "type": "example",
          "vi": "Cho em một cà phê đen ít đường.",
          "en": "I'll have one black coffee with less sugar."
        }
      ]
    }
  ]
}
