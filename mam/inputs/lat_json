{
  "id": "lat",
  "title": "lát / lát nữa",
  "terms": [
    "lát"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "\"lát\" / \"lát nữa\" (later / in a moment). Indicates something will happen soon, after a short while."
        }
      ]
    },
    {
      "label": "Structure",
      "blocks": [
        {
          "type": "text",
          "text": "Lát nữa + [subject] + [verb]  —  In a bit, [subject] will [verb]"
        },
        {
          "type": "text",
          "text": "[Subject] + [verb] + lát nữa  —  [Subject] will [verb] later"
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Lát mình đi ăn.",
          "en": "Later, I'll go eat."
        },
        {
          "type": "example",
          "vi": "Lát gặp lại.",
          "en": "See you later."
        },
        {
          "type": "example",
          "vi": "Lát nữa mình gọi cho bạn.",
          "en": "I'll call you in a moment."
        }
      ]
    }
  ]
}
