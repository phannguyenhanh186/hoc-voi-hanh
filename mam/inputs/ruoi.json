{
  "id": "ruoi",
  "title": "rưỡi",
  "terms": [
    "rưỡi"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "\"rưỡi\" (half / half past). Used after \"giờ\" to indicate \"half past\" the hour (i.e., 30 minutes)."
        }
      ]
    },
    {
      "label": "Structure",
      "blocks": [
        {
          "type": "text",
          "text": "[x] giờ rưỡi  —  half past [x] / [x]:30"
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Bây giờ là 7 giờ rưỡi.",
          "en": "It's 7:30 now."
        },
        {
          "type": "example",
          "vi": "Mình ăn cơm lúc 6 giờ rưỡi tối.",
          "en": "I eat dinner at 6:30pm."
        },
        {
          "type": "example",
          "vi": "Lớp học bắt đầu lúc 8 giờ rưỡi sáng.",
          "en": "Class starts at 8:30am."
        }
      ]
    },
    {
      "label": "Note",
      "blocks": [
        {
          "type": "text",
          "text": "\"rưỡi\" equals \"30 phút\" — so \"7 giờ rưỡi\" = \"7 giờ 30 phút\" (7:30), but \"rưỡi\" is more natural in spoken Vietnamese for the half-hour."
        }
      ]
    }
  ]
}
