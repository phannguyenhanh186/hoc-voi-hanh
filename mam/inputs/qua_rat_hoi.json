{
  "id": "qua_rat_hoi",
  "title": "quá / rất / hơi",
  "terms": [
    "hơi",
    "quá",
    "rất"
  ],
  "sections": [
    {
      "label": "hơi (a bit)",
      "blocks": [
        {
          "type": "text",
          "text": "Mild / slight degree — placed before the adjective; a lesser degree than \"rất,\" often to soften or hint at something not entirely positive."
        },
        {
          "type": "text",
          "text": "Structure: hơi + [adjective]"
        },
        {
          "type": "example",
          "vi": "Cái này hơi mắc.",
          "en": "This is a bit expensive."
        },
        {
          "type": "example",
          "vi": "Hôm nay hơi lạnh.",
          "en": "Today is a bit cold."
        },
        {
          "type": "example",
          "vi": "Mình hơi mệt.",
          "en": "I'm a bit tired."
        }
      ]
    },
    {
      "label": "quá (so)",
      "blocks": [
        {
          "type": "text",
          "text": "Intensified degree — \"too much\" or \"so,\" often with emotional emphasis."
        },
        {
          "type": "text",
          "text": "Structure: [adjective] + quá!"
        },
        {
          "type": "example",
          "vi": "Ngon quá!",
          "en": "So delicious! / Too delicious!"
        },
        {
          "type": "example",
          "vi": "Đắt quá!",
          "en": "Too expensive!"
        },
        {
          "type": "example",
          "vi": "Hôm nay nóng quá.",
          "en": "Today is so hot."
        },
        {
          "type": "example",
          "vi": "Cà phê này ngon quá!",
          "en": "This coffee is really delicious!"
        }
      ]
    },
    {
      "label": "rất (very)",
      "blocks": [
        {
          "type": "text",
          "text": "High degree — placed before the adjective."
        },
        {
          "type": "text",
          "text": "Structure: rất + [adjective]"
        },
        {
          "type": "example",
          "vi": "Cà phê này rất ngon.",
          "en": "This coffee is very delicious."
        },
        {
          "type": "example",
          "vi": "Mình rất thích bạn.",
          "en": "I like you a lot."
        },
        {
          "type": "example",
          "vi": "Chị ấy rất bận.",
          "en": "She is very busy."
        }
      ]
    },
    {
      "label": "rất vs quá",
      "blocks": [
        {
          "type": "text",
          "text": "rất = calm, descriptive (\"very\") — normal statements."
        },
        {
          "type": "text",
          "text": "quá = exclamatory, emotional (\"too / so\") — implies the degree is excessive or surprising, used with \"!\""
        }
      ]
    }
  ]
}