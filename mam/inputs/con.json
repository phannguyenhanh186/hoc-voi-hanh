{
  "id": "con",
  "title": "Còn",
  "terms": [
    "còn"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "\"còn\" here means \"and… ?\" or \"what about… ?\" — used to ask the same question back to someone, or to shift to a related/contrasting topic."
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Em khoẻ. Còn chị?",
          "en": "I'm fine. And you?"
        },
        {
          "type": "example",
          "vi": "Chị là người Việt. Còn em?",
          "en": "I'm Vietnamese. And you?"
        },
        {
          "type": "example",
          "vi": "Mình tên là Hải. Còn bạn?",
          "en": "My name's Hải. And you?"
        }
      ]
    }
  ]
}
