{
  "id": "gi_nua",
  "title": "gì nữa",
  "terms": [
    "gì nữa",
    "nữa"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "\"nữa\" means \"more/else/again,\" and \"gì nữa\" together means \"what else / anything else.\""
        }
      ]
    },
    {
      "label": "Structure",
      "blocks": [
        {
          "type": "text",
          "text": "[Verb] + gì nữa (+ không)?"
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "vi": "Anh chị muốn dùng gì nữa không?",
          "en": "Would you like anything else?"
        },
        {
          "type": "example",
          "vi": "Bạn muốn ăn gì nữa không?",
          "en": "Do you want to eat anything else?"
        },
        {
          "type": "example",
          "vi": "Em cần gì nữa không?",
          "en": "Do you need anything else?"
        }
      ]
    },
    {
      "label": "Answering",
      "blocks": [
        {
          "type": "example",
          "vi": "Dạ không, cảm ơn.",
          "en": "No, thank you."
        },
        {
          "type": "example",
          "vi": "Có, cho em thêm một cà phê.",
          "en": "Yes, I'll also have one more coffee."
        }
      ]
    },
    {
      "label": "Note",
      "blocks": [
        {
          "type": "text",
          "text": "\"nữa\" alone can attach to other words too — thêm một cái nữa (one more), ăn nữa (eat more/again), đi nữa (go again)."
        }
      ]
    }
  ]
}
