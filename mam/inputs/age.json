      "label": "Structure",
      "blocks": [
        {
          "type": "text",
          "text": "Question: [Pronoun] bao nhiêu tuổi?  —  How old are you / is [pronoun]?"
        },
        {
          "type": "text",
          "text": "Answer: [Pronoun] [x] tuổi.  —  [Pronoun] is [x] years old."
        }
      ]
    },
    {
      "label": "Example",
