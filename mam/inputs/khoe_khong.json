{
  "id": "khoe_khong",
  "title": "Khoẻ không?",
  "terms": [
    "khoẻ",
    "không"
  ],
  "sections": [
    {
      "label": "Explanation",
      "blocks": [
        {
          "type": "text",
          "text": "A casual greeting between friends or peers: \"Bạn khoẻ không?\" – \"Mình khoẻ.\" means \"Are you well? / How are you?\" – \"I'm fine / well.\""
        },
        {
          "type": "table",
          "columns": [
            "Word",
            "Meaning"
          ],
          "rows": [
            [
              "khoẻ",
              "healthy / well"
            ],
            [
              "không?",
              "turns the sentence into a yes/no question"
            ]
          ]
        },
        {
          "type": "text",
          "text": "Other pronouns work the same way as mình/bạn — just swap in the appropriate pronoun for both speaker and listener."
        }
      ]
    },
    {
      "label": "Example",
      "blocks": [
        {
          "type": "example",
          "context": "Friends / peers",
          "vi": "Bạn khoẻ không? – Mình khoẻ.",
          "en": "How are you? – I'm fine."
        },
        {
          "type": "example",
          "context": "Asking an older male",
          "vi": "Anh khoẻ không? – Anh khoẻ.",
          "en": "Are you well? – I'm well."
        },
        {
          "type": "example",
          "context": "Asking an older female",
          "vi": "Chị khoẻ không? – Chị khoẻ.",
          "en": "Are you well? – I'm well."
        },
        {
          "type": "example",
          "context": "Asking a younger person",
          "vi": "Em khoẻ không? – Em khoẻ.",
          "en": "Are you well? – I'm well."
        }
      ]
    }
  ]
}